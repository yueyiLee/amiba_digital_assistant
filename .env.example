# ============================================================
# 阿米巴经营数字助手 — 环境变量配置
# ============================================================
# 使用方法：复制本文件为 .env，填入实际值后运行 npm run dev
#   cp .env.example .env
#
# 部署到 CloudBase 时：云端环境变量在控制台配置，无需 .env 文件
# （TENCENTCLOUD_* 由 CloudBase 运行时自动注入）
# ============================================================


# ---------- 服务端口 ----------
PORT=3000


# ---------- PostgreSQL 数据库（本地开发用） ----------
# CloudBase 部署时无需配置，走 executePGSql 访问环境内置 PostgreSQL
PG_USER=amoeba
PG_HOST=localhost
PG_DATABASE=amoeba_app
PG_PASSWORD=amoeba123
PG_PORT=5432


# ---------- JWT 认证密钥 ----------
# 生产环境务必修改为随机长字符串（用于签发和校验登录 Token）
JWT_SECRET=amoeba-demo-secret-2026


# ---------- CloudBase 环境（云端部署用，本地无需配置） ----------
# 云端运行时 TENCENTCLOUD_* 由平台自动注入，以下仅需在本地调试云函数时手动填
# TENCENTCLOUD_SECRETID=
# TENCENTCLOUD_SECRETKEY=
# TENCENTCLOUD_SESSIONTOKEN=
# CloudBase 环境 ID
TCB_ENV=amiba-d3gk34ae899822073


# ---------- AI 对话助手 LLM 配置 ----------
# 兼容 OpenAI / DeepSeek / 通义千问等 OpenAI 格式 API
# 推荐 DeepSeek（性价比高，支持 Function Calling）

# 方式一：DeepSeek（推荐）
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 方式二：OpenAI
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# 方式三：通义千问（兼容 OpenAI 格式）
# LLM_API_KEY=sk-xxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
